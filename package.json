{
  "name": "openrct2.org",
  "version": "3.3.1",
  "private": false,
  "scripts": {
    "watchFrontend": "webpack --watch --config ./frontend/webpack.config.js",
    "buildFrontend": "webpack --config ./frontend/webpack.config.js",
    "monitorTimeout": "ping 127.0.0.1 -n 8 > nul",
    "buildServer": "babel src --out-dir dist --delete-dir-on-start --copy-files --source-maps",
    "watchServer": "babel src --out-dir dist --delete-dir-on-start --copy-files --source-maps --watch",
    "build": "npm run buildServer && npm run buildFrontend",
    "startMon": "npm run monitorTimeout && nodemon -e js,marko,json --watch dist --watch config dist/app.js",
    "watch": "concurrently --prefix \"[{time} {name}]\" --timestamp-format \"HH:mm:ss.SSS\" \"npm:watchServer\" \"npm:startMon\" \"npm:watchFrontend\"",
    "test": "eslint --ext .js src/ && eslint --ext .js frontend/"
  },
  "author": {
    "name": "Limetric",
    "email": "info+openrct2@limetric.com",
    "url": "https://limetric.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JarnoVgr/OpenRCT2.org.git"
  },
  "browserslist": [
    "last 2 iOS versions, last 2 and_ff versions, last 2 ChromeAndroid versions, last 3 safari versions, last 3 chrome versions, last 3 firefox versions, last 3 edge versions, last 3 opera versions, not dead"
  ],
  "dependencies": {
    "@octokit/rest": "^18.6.7",
    "@sentry/node": "^6.9.0",
    "body-parser": "~1.19.0",
    "chalk": "^4.1.1",
    "core-js": "^3.15.2",
    "express": "~4.17.1",
    "express-async-errors": "^3.1.1",
    "glob": "^7.1.7",
    "lodash": "^4.17.21",
    "marko": "^5.12.0",
    "moment": "^2.29.1",
    "multer": "^1.4.2",
    "mysql": "^2.18.1",
    "normalize.css": "^8.0.1",
    "object-hash": "^2.2.0",
    "regenerator-runtime": "^0.13.7",
    "request": "^2.88.2",
    "request-promise-native": "^1.0.9",
    "source-map-support": "^0.5.19"
  },
  "devDependencies": {
    "@babel/cli": "^7.14.5",
    "@babel/core": "^7.14.6",
    "@babel/preset-env": "^7.14.7",
    "@babel/eslint-parser": "^7.14.7",
    "@babel/eslint-plugin": "^7.14.5",
    "@babel/register": "^7.14.5",
    "@babel/traverse": "^7.14.7",
    "@sentry/webpack-plugin": "^1.16.0",
    "autoprefixer": "^10.3.1",
    "babel-loader": "^8.2.2",
    "clean-webpack-plugin": "^3.0.0",
    "concurrently": "^6.2.0",
    "css-loader": "^6.0.0",
    "cssnano": "^5.0.6",
    "eslint": "^7.30.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-plugin-babel": "^5.3.1",
    "eslint-plugin-import": "^2.23.4",
    "eslint-plugin-jsdoc": "^35.4.3",
    "eslint-plugin-promise": "^5.1.0",
    "mini-css-extract-plugin": "^2.1.0",
    "moment-locales-webpack-plugin": "^1.2.0",
    "node-sass": "^6.0.1",
    "nodemon": "^2.0.12",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-loader": "^6.1.1",
    "sass-loader": "^12.1.0",
    "webpack": "^5.44.0",
    "webpack-bundle-analyzer": "^4.4.2",
    "webpack-cli": "^4.7.2",
    "webpack-notifier": "^1.13.0",
    "terser-webpack-plugin": "^5.1.4"
  }
}
